# ============================================
# SUPABASE - Variables de entorno requeridas
# ============================================
# NO hagas commit de .env.local (usa .env.example como referencia)
# Crea .env.local en la raíz del proyecto con tus valores reales

# URL pública de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública para el cliente (segura exponerse en frontend)
# Obtén en: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ⚠️ CRÍTICO: Clave de servicio - NUNCA exponer públicamente
# Solo usar en scripts backend, Next.js API routes, variables de entorno servidor
# Regenera si has comprometido esta key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ============================================
# VARIABLES PARA TESTING Y SCRIPTS
# ============================================

# Para test-upload-evidencia.mjs
TEST_EMAIL=usuario-test@example.com
TEST_PASSWORD=contraseña-test-segura

# Para crearUsuariosPrueba.js
DEFAULT_TEST_PASSWORD=contraseña-test-usuarios

# ============================================
# DESARROLLO LOCAL
# ============================================

# Para desarrollo en localhost
BASE_URL=http://localhost:3000

# ============================================
# INSTRUCCIONES
# ============================================
#
# 1️⃣  Obtén tus credenciales Supabase:
#     • Ve a https://app.supabase.com
#     • Abre tu proyecto
#     • Settings → API → Copia las keys
#
# 2️⃣  Crea .env.local:
#     cp .env.example .env.local
#
# 3️⃣  Edita .env.local y completa con tus valores reales
#
# 4️⃣  IMPORTANTE: .env.local está en .gitignore (NO se sube a GitHub)
#
# 5️⃣  Scripts que necesitan SERVICE_ROLE_KEY:
#     node scripts/crearAdminItFlow.js
#     node scripts/crearUsuariosPrueba.js
#     node scripts/crear-tareas-prueba-supervisor.js
#
# ============================================
# SEGURIDAD - NORMAS CRÍTICAS
# ============================================
#
# ❌ NUNCA hagas commit de:
#    • .env.local (contiene secretos reales)
#    • Service role keys en archivos .js
#    • Credenciales en código fuente
#    • URLs con secretos
#
# ✅ SIEMPRE:
#    • Lee secretos desde process.env
#    • Carga .env.local con dotenv
#    • Mantén .env.local en .gitignore
#    • Haz .env.example sin valores sensibles
#
# 🔑 SI EXPONES UNA KEY ACCIDENTALMENTE:
#    1. DETÉN TODO INMEDIATAMENTE
#    2. Ve a Supabase Dashboard
#    3. Regenera la key en Settings → API
#    4. Limpia el historial de Git
#    5. Hace nuevo push
#    6. Comunica a tu equipo
#
# ============================================

